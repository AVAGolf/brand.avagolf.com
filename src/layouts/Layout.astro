---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: "website" | "article";
}

const {
  title = "AVA Golf — Brand Guidelines",
  description = "Brand identity, design tokens, and guidelines for AVA Golf — logo marks, color palette, typography, and application principles.",
  image = "/og-image.png",
  ogType = "website",
} = Astro.props;

const site = Astro.site ?? new URL("https://brand.avagolf.com");
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const socialImage = new URL(image, site).href;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "AVA Golf, Inc.",
  alternateName: "AVA Golf",
  url: "https://avagolf.com",
  logo: "https://brand.avagolf.com/avagolf-sxs-color.svg",
  description: "AVA Golf is the first golf intelligence system, unifying player data from simulators, launch monitors, and on-course tracking to deliver personalized coaching and improvement plans.",
  sameAs: [
    "https://www.instagram.com/avagolfofficial/",
    "https://www.linkedin.com/company/avagolf/",
    "https://www.youtube.com/@avagolfofficial",
    "https://facebook.com/avagolf",
    "https://www.tiktok.com/@ava.golf"
  ],
  parentOrganization: {
    "@type": "Organization",
    name: "ParOne, Inc.",
    url: "https://parone.com"
  }
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "AVA Golf Brand Guidelines",
  url: "https://brand.avagolf.com",
  description: "Official brand guidelines for AVA Golf — covering logo marks, color palette, typography, brand elements, and communication principles.",
  version: "1.0.0",
  publisher: {
    "@type": "Organization",
    name: "AVA Golf, Inc.",
    url: "https://avagolf.com"
  },
  mainEntity: {
    "@type": "CreativeWork",
    name: "AVA Golf Brand Identity System",
    description: "Complete visual and communication identity for AVA Golf including logo marks, color palette, typography, brand elements, and voice guidelines.",
    creator: {
      "@type": "Organization",
      name: "AVA Golf, Inc."
    }
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Essentials -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="author" content="AVA Golf" />

    <!-- Theme / color scheme -->
    <meta name="theme-color" content="#070e0c" />
    <meta name="color-scheme" content="light dark" />

    <!-- Icons / PWA -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="AVA Golf — Brand Guidelines" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="AVA Golf — Brand Guidelines" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content="AVA Golf — Brand Guidelines" />

    <!-- Fonts: preload critical above-the-fold fonts -->
    <link
      rel="preload"
      href="/fonts/GoogleSansFlex.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/ConstructMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/DMMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Page-specific head -->
    <slot name="head" />

    <ClientRouter />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(organizationSchema)}
    />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(webSiteSchema)}
    />
  </head>
  <body>
    <slot />
  </body>
</html>