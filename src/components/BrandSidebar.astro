---
import { sectionsByGroup, groupOrder } from "../lib/sections";

interface Props {
  activeSlug?: string;
}

const { activeSlug } = Astro.props;
const groups = sectionsByGroup();
---

<div
  class="bg-dark-green-500 border-dark-green-300 sticky top-0 z-30 flex h-14 items-center justify-between border-b px-5 lg:hidden"
>
  <a href="/" class="flex items-center">
    <img src="/avagolf-sxs-color.svg" alt="AVA Golf" class="h-7 w-auto" />
  </a>
  <button
    type="button"
    data-nav-toggle
    aria-label="Open navigation"
    aria-expanded="false"
    aria-controls="brand-nav"
    class="text-white hover:bg-dark-green-700 inline-flex h-10 w-10 items-center justify-center rounded-md transition-colors"
  >
    <svg
      data-nav-icon-open
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M3 6h18M3 12h18M3 18h18"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      ></path>
    </svg>
    <svg
      data-nav-icon-close
      class="hidden"
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M6 6l12 12M18 6L6 18"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      ></path>
    </svg>
  </button>
</div>

<div
  data-nav-backdrop
  class="bg-dark-green-900/70 fixed inset-0 z-30 hidden lg:hidden"
  aria-hidden="true"
>
</div>

<aside
  id="brand-nav"
  data-nav-drawer
  class="bg-dark-green-500 shadow-sidebar fixed inset-y-0 left-0 z-40 flex w-[260px] max-w-[80vw] -translate-x-full flex-col transition-transform duration-200 ease-out lg:translate-x-0"
>
  <div class="border-dark-green-300 border-b px-12 py-8 text-center">
  <a href="/" class="flex justify-center">
    <img src="/avagolf-sxs-color.svg" alt="AVA Golf" class="h-9 w-auto" />
  </a>
  <p class="text-micro text-green-300 mt-6 uppercase tracking-widest">
    Brand Guidelines
  </p>
</div>

  <nav class="scrollbar-hide flex-1 overflow-y-auto py-8">
    {
      groupOrder.map((group) => (
        <div class="mb-8 last:mb-0">
          <p class="text-label text-white mb-4 px-12 font-bold uppercase tracking-widest">
            {group}
          </p>
          <ul>
            {groups[group].map((s) => {
              const isActive = s.slug === activeSlug;
              return (
                <li>
                  <a
                    href={`/${s.slug}`}
                    class:list={[
                      "text-nav relative flex h-9 items-center px-12 font-normal uppercase tracking-widest transition-colors",
                      isActive
                        ? "bg-dark-green-900 text-bright-green-500"
                        : "text-grey-300 hover:bg-dark-green-700 hover:text-white",
                    ]}
                  >
                    <span>{s.title}</span>
                    {isActive && (
                      <span
                        aria-hidden="true"
                        class="text-bright-green-500 absolute right-3 text-xl leading-none"
                      >
                        ◄
                      </span>
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>

<script>
  function setNavOpen(open: boolean) {
    const drawer = document.querySelector<HTMLElement>("[data-nav-drawer]");
    const backdrop = document.querySelector<HTMLElement>(
      "[data-nav-backdrop]",
    );
    const toggle = document.querySelector<HTMLElement>("[data-nav-toggle]");
    const iconOpen = document.querySelector<HTMLElement>(
      "[data-nav-icon-open]",
    );
    const iconClose = document.querySelector<HTMLElement>(
      "[data-nav-icon-close]",
    );
    if (!drawer || !backdrop || !toggle) return;

    drawer.classList.toggle("-translate-x-full", !open);
    backdrop.classList.toggle("hidden", !open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute(
      "aria-label",
      open ? "Close navigation" : "Open navigation",
    );
    iconOpen?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
    document.body.style.overflow = open ? "hidden" : "";
  }

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (target.closest("[data-nav-toggle]")) {
      const toggle = document.querySelector<HTMLElement>("[data-nav-toggle]");
      const isOpen = toggle?.getAttribute("aria-expanded") === "true";
      setNavOpen(!isOpen);
      return;
    }
    if (target.closest("[data-nav-backdrop]")) {
      setNavOpen(false);
      return;
    }
    if (target.closest("[data-nav-drawer] a")) {
      setNavOpen(false);
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setNavOpen(false);
  });

  document.addEventListener("astro:before-swap", () => {
    document.body.style.overflow = "";
  });
</script>
