---
import BrandLayout from "../layouts/BrandLayout.astro";
import ColorSwatch from "../components/ColorSwatch.astro";
import { greens, yellows, neutrals, brightGreen, darkGreens, reds, gradients } from "../lib/colors";
---

<BrandLayout
  slug="colors"
  eyebrow="Core Identity"
  title="Color"
>
  <div class="mx-auto max-w-6xl space-y-20">
    <!-- PRIMARY PALETTE -->
    <section>
      <header class="mb-8">
        <h2 class="text-h2 text-dark-green-900 mb-3">Primary Palette</h2>
        <p class="text-body text-dark-green-700">These are the core identity colors.</p>
      </header>

      <!-- Hero grid: 2 large greens + a stacked yellow/white column -->
      <div class="mb-12 grid grid-cols-5 gap-2" style="aspect-ratio: 5 / 2;">
        <ColorSwatch
          name="green-500"
          hex="#349683"
          textClass="text-white"
          size="lg"
          class="col-span-2 h-full"
        />
        <ColorSwatch
          name="green-900"
          hex="#16382E"
          textClass="text-white"
          size="lg"
          class="col-span-2 h-full"
        />
        <div class="col-span-1 flex flex-col gap-2">
          <ColorSwatch name="yellow-500" hex="#FFE708" textClass="text-dark-green-900" size="sm" class="flex-1" />
          <ColorSwatch name="yellow-300" hex="#FFFF4A" textClass="text-dark-green-900" size="sm" class="flex-1" />
          <ColorSwatch name="white" hex="#FFFFFF" textClass="text-dark-green-900" size="sm" class="flex-1" />
        </div>
      </div>

      <!-- Greens row -->
      <div class="mb-10">
        <h3 class="text-eyebrow text-dark-green-900 mb-4">Green</h3>
        <div class="grid grid-cols-4 gap-2">
          {greens.map((c) => (
            <ColorSwatch
              name={c.name}
              hex={c.hex}
              cmyk={c.cmyk}
              textClass={c.text}
              class="aspect-[3/2]"
            />
          ))}
        </div>
      </div>

      <!-- Yellows row -->
      <div class="mb-10">
        <h3 class="text-eyebrow text-dark-green-900 mb-4">Yellow</h3>
        <div class="grid grid-cols-4 gap-2">
          {yellows.map((c) => (
            <ColorSwatch
              name={c.name}
              hex={c.hex}
              cmyk={c.cmyk}
              textClass={c.text}
              class="aspect-[3/2]"
            />
          ))}
        </div>
      </div>

      <!-- Neutrals row -->
      <div>
        <h3 class="text-eyebrow text-dark-green-900 mb-4">White / Grey</h3>
        <div class="grid grid-cols-4 gap-2">
          {neutrals.map((c) => (
            <ColorSwatch
              name={c.name}
              hex={c.hex}
              cmyk={c.cmyk}
              textClass={c.text}
              class="aspect-[3/2] border border-green-500/30"
            />
          ))}
        </div>
      </div>
    </section>

    <!-- SECONDARY PALETTE -->
    <section>
      <header class="mb-8 border-t border-green-500/30 pt-12">
        <h2 class="text-h2 text-dark-green-900 mb-3">Secondary Palette</h2>
      </header>

      <div class="mb-10">
        <h3 class="text-eyebrow text-dark-green-900 mb-4">Bright Green</h3>
        <div class="grid grid-cols-4 gap-2">
          {brightGreen.map((c) => (
            <ColorSwatch
              name={c.name}
              hex={c.hex}
              cmyk={c.cmyk}
              textClass={c.text}
              class="aspect-[3/2]"
            />
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-eyebrow text-dark-green-900 mb-4">Dark Green</h3>
        <div class="grid grid-cols-4 gap-2">
          {darkGreens.map((c) => (
            <ColorSwatch
              name={c.name}
              hex={c.hex}
              cmyk={c.cmyk}
              textClass={c.text}
              class="aspect-[3/2]"
            />
          ))}
        </div>
      </div>
    </section>

    <!-- RED PALETTE -->
    <section>
      <header class="mb-8 border-t border-green-500/30 pt-12">
        <h2 class="text-h2 text-dark-green-900 mb-3">Red</h2>
      </header>

      <div class="grid grid-cols-5 gap-2">
        {reds.map((c) => (
          <ColorSwatch
            name={c.name}
            hex={c.hex}
            textClass={c.text}
            class="aspect-[3/2]"
          />
        ))}
      </div>
    </section>

    <!-- GRADIENTS -->
    <section>
      <header class="mb-8 border-t border-green-500/30 pt-12">
        <h2 class="text-h2 text-dark-green-900 mb-3">Gradients</h2>
        <p class="text-body text-dark-green-700">Color blends.</p>
      </header>

      <!-- Hero gradient strip -->
      <div class="mb-12 grid grid-cols-3 gap-2" style="aspect-ratio: 3 / 1;">
        {gradients.map((g) => (
          <div
            class:list={["relative flex flex-col justify-end rounded-md p-8", g.text]}
            style={`background: linear-gradient(90deg, ${g.from} 0%, ${g.to} 100%)`}
          >
            <p class="text-button">{g.name}</p>
          </div>
        ))}
      </div>

      <!-- Per-gradient breakdown rows -->
      {gradients.map((g) => (
        <div class="mb-10">
          <h3 class="text-eyebrow text-dark-green-900 mb-4">{g.name}</h3>
          <div class="grid grid-cols-[1fr_auto_1fr] items-stretch gap-3">
            <ColorSwatch
              name="From"
              hex={g.from}
              textClass={g.text}
              class="aspect-[5/2]"
            />
            <div class="flex items-center justify-center text-green-500 text-2xl">›</div>
            <ColorSwatch
              name="To"
              hex={g.to}
              textClass={g.text}
              class="aspect-[5/2]"
            />
          </div>
        </div>
      ))}
    </section>
  </div>
</BrandLayout>
