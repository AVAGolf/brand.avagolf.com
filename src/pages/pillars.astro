---
import BrandLayout from "../layouts/BrandLayout.astro";

const pillars = [
  {
    title: "Direction with Data",
    body: "AVA consolidates performance data across a golfer's ecosystem — simulation sessions, launch monitor readings, and on-course results — and interprets it as a unified system. This creates a new category of Golf Intelligence that focuses on insight rather than raw data.",
  },
  {
    title: "Personalized Progression",
    body: "Rather than offering endless drills or generic content, AVA creates a structured improvement pathway tailored to each golfer's performance profile. The system evolves as the golfer improves, ensuring progress remains relevant and focused.",
  },
  {
    title: "Mastery without Guesswork",
    body: "AVA empowers golfers to become their own coach. By removing guesswork and aligning their tools, data, and practice routines, golfers can improve with confidence on their own terms.",
  },
];
---

<BrandLayout
  slug="pillars"
  eyebrow="Communication"
  title="Pillars"
>
  <div class="mx-auto max-w-6xl space-y-12">
    <section>
      <h2 class="text-h2 text-dark-green-900 mb-4">Our Pillars</h2>
      <p class="text-body text-dark-green-700 max-w-3xl">
        AVA is built around three core pillars: transforming data into clear
        direction, creating personalized improvement pathways, and helping
        golfers improve with confidence. Together, these principles position
        AVA as more than a tracking tool — a system designed to guide golfers
        toward smarter, more structured progression.
      </p>
    </section>

    <section class="border-t border-green-500/30 pt-12">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
        {
          pillars.map((p) => (
            <article>
              <h3 class="text-h2 text-green-900 mb-4">{p.title}</h3>
              <p class="text-body text-dark-green-700">{p.body}</p>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</BrandLayout>
