---
import BrandLayout from "../layouts/BrandLayout.astro";

const segments = [
    {
        title: "The Competitive Improver",
        body: "Dedicated golfers who actively work to lower their handicap and measure progress. They take pride in their form and how they compare to their friends. They take lessons, analyze their rounds, and invest in tools that help them improve. They value structure and clarity in their development rather than scattered tips or guesswork.",
    },
    {
        title: "The Tech-Enabled Golfer",
        body: "Golfers who already use simulators, launch monitors, shot-tracking apps, or swing analysis tools. They appreciate data but often struggle to interpret it effectively. AVA Golf becomes the system that connects and translates this information into clear actions.",
    },
    {
        title: "The Self-Guided Athlete",
        body: "Golfers who want to take ownership of their improvement. They practice independently, study their performance, and seek marginal gains through disciplined effort. AVA Golf empowers them with a structured pathway that helps them to master their game with confidence.",
    },
];
---

<BrandLayout slug="audience" eyebrow="Communication" title="Audience">
    <div class="mx-auto max-w-6xl space-y-12">
        <section>
            <h2 class="text-h2 text-dark-green-900 mb-4">Our Audience</h2>
            <p class="text-body text-dark-green-700 max-w-3xl">
                AVA Golf is built for committed golfers who are actively invested in
                improving their performance. They are data-aware, self-motivated
                players who use technology, track progress, and value structured
                guidance over guesswork. Whether through simulators, coaching,
                or independent practice, they are constantly seeking smarter
                ways to refine their game and gain a competitive edge.
                Every decision we make — in how we
communicate, design, and deliver — is shaped by a deep understanding of who they are
and what drives them.
            </p>
        </section>

        <section class="border-t border-green-500/30 pt-12">
            <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
                {
                    segments.map((s) => (
                        <article>
                            <h3 class="text-h2 text-green-900 mb-4">
                                {s.title}
                            </h3>
                            <p class="text-body text-dark-green-700">
                                {s.body}
                            </p>
                        </article>
                    ))
                }
            </div>
        </section>

        <section class="border-t border-green-500/30 pt-12">
            <div class="grid grid-cols-1 gap-10 md:grid-cols-2">
                <article>
                    <h3 class="text-h2 text-green-900 mb-4">
                        We Are <span
                            class="underline decoration-green-900 decoration-4 underline-offset-4"
                            >Not</span
                        >
                    </h3>
                    <p class="text-body text-dark-green-700">
                        AVA Golf is for golfers who are serious about improvement — committed players who
already invest in their game and are ready to take that commitment further. This is not
an entry-level platform, and it is never elitist. Progress here is earned through data,
discipline, and honest self-assessment.
                    </p>
                </article>
                <article>
                    <h3 class="text-h2 text-green-900 mb-4">Considerations</h3>
                    <div class="text-body text-dark-green-700 space-y-4">
                        <p>
                            While AVA is designed for the committed golfer, we are dedicated to making that path
as accessible as possible — building a platform, instructor base, and community that
reflects the full diversity of golfers who take their game seriously.
                        </p>
                    </div>
                </article>
            </div>
        </section>
    </div>
</BrandLayout>
